{
  "name": "@relaycron/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for AgentCron — schedule work for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relaycron",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@relaycron/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
